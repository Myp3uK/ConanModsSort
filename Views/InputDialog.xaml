<Window x:Class="ConanModsSort.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ввод" SizeToContent="Height" Width="460"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="False"
        WindowStartupLocation="CenterOwner" Background="#1C1C25"
        FontFamily="Segoe UI" TextOptions.TextFormattingMode="Display">
    <Border BorderBrush="#3A7BD5" BorderThickness="1" Padding="20">
        <StackPanel>
            <TextBlock x:Name="TitleText" Foreground="#E8E8EE" FontSize="15" FontWeight="SemiBold"
                       Margin="0,0,0,8" MouseLeftButtonDown="TitleBar_Drag"/>
            <TextBlock x:Name="PromptText" Foreground="#8A8A98" FontSize="12.5"
                       TextWrapping="Wrap" Margin="0,0,0,12"/>
            <TextBox x:Name="Input" Background="#13131A" Foreground="#E8E8EE" CaretBrush="#E8E8EE"
                     BorderBrush="#2E2E3A" BorderThickness="1" Padding="8,7" FontSize="13"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="OK" Width="94" Height="32" IsDefault="True" Click="Ok_Click"
                        Background="#3A7BD5" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Отмена" Width="94" Height="32" IsCancel="True" Margin="8,0,0,0"
                        Background="#2A2A36" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
