<Window x:Class="ConanModsSort.CodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        SizeToContent="Height" Width="400"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="False"
        ShowInTaskbar="False" WindowStartupLocation="CenterOwner" Background="#1C1C25"
        FontFamily="Segoe UI" TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style x:Key="DlgBtn" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="94"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2A2A36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="6" Background="{TemplateBinding Background}"
                                Padding="14,0" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#363645"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DlgAccent" TargetType="Button" BasedOn="{StaticResource DlgBtn}">
            <Setter Property="Background" Value="#3A7BD5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="6" Background="{TemplateBinding Background}"
                                Padding="14,0" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#4C8DEA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#3A7BD5" BorderThickness="1" Padding="20">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12" Background="Transparent"
                        MouseLeftButtonDown="TitleBar_Drag">
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="20" Text="&#xE928;"
                           Foreground="#3A7BD5" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Steam Guard" Foreground="#E8E8EE" FontSize="15" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock x:Name="PromptText" Foreground="#C8C8D2" FontSize="13"
                       TextWrapping="Wrap" Margin="0,0,0,14"/>

            <TextBox x:Name="txtCode" Height="36" Background="#12121A" Foreground="#E8E8EE"
                     CaretBrush="#E8E8EE" BorderBrush="#33333F" BorderThickness="1"
                     Padding="10,6" VerticalContentAlignment="Center" FontSize="18"
                     FontFamily="Consolas" CharacterCasing="Upper" MaxLength="10" Margin="0,0,0,18"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" Style="{StaticResource DlgAccent}" IsDefault="True" Click="Ok_Click"/>
                <Button Content="Отмена" Style="{StaticResource DlgBtn}" IsCancel="True" Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
